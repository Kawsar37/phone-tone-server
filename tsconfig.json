{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./api",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["api/*"]
    }
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "dist"]
}
